# Xero Custom Connection (developer.xero.com -> My Apps -> Custom Connection)
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=

# Anthropic (transcript/contract/email parsing)
ANTHROPIC_API_KEY=

# Postgres (docker compose default)
DATABASE_URL=postgres://robyn:robyn@localhost:5432/robyn

# Demo mailbox via IMAP (Gmail: app password, imap.gmail.com:993)
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=

# Google Calendar OAuth (optional - .ics fallback exists if empty)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

PORT=3000
GOOGLE_REDIRECT_URI=http://localhost:3001/calendar/callback
