# Xero Custom Connection (client_credentials — single org, no OAuth redirect)
# Create at https://developer.xero.com/app/manage → New app → Custom connection.
# Scopes to select at app creation: accounting.transactions accounting.contacts
#   accounting.attachments accounting.reports.read
# The org admin must authorise the connection before tokens will be issued.
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
# Space-separated. Must exactly match the scopes assigned to the app in the
# developer portal — requesting a scope the app lacks fails with invalid_scope.
XERO_SCOPES=accounting.transactions accounting.contacts accounting.attachments accounting.reports.read

# Gate G0 check once filled in:
#   npx tsx .claude/skills/xero-auth/scripts/verify-auth.ts
